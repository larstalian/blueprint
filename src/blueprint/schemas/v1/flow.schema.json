{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "trigger",
    "steps"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "unit"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "contract": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "call"
            ],
            "properties": {
              "call": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "emit"
            ],
            "properties": {
              "emit": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "subscribe"
            ],
            "properties": {
              "subscribe": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      }
    }
  }
}

