{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "layers",
    "allowed_dependencies",
    "forbidden_imports",
    "side_effect_defaults"
  ],
  "properties": {
    "layers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_dependencies": {
      "type": "object",
      "propertyNames": {
        "minLength": 1
      },
      "additionalProperties": {
        "type": "array",
        "uniqueItems": true,
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "forbidden_imports": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "side_effect_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "network",
        "filesystem"
      ],
      "properties": {
        "network": {
          "type": "boolean"
        },
        "filesystem": {
          "type": "boolean"
        }
      }
    }
  }
}

